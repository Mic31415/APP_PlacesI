# Resolve react_native_pods.rb with node to allow for hoisting
def node_require(script)
  require Pod::Executable.execute_command('node', ['-p',
    "require.resolve(
      '#{script}',
      {paths: [process.argv[1]]},
    )", __dir__]).strip
end

node_require('react-native/scripts/react_native_pods.rb')
node_require('react-native-permissions/scripts/setup.rb')

setup_permissions([
  'AppTrackingTransparency',
])

platform :ios, min_ios_version_supported
prepare_react_native_project!

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'PlacesI' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )
    
    # Remove duplicate ttf files from Copy Bundle Resources (Project Level) to avoid "Multiple commands produce" error
    # generated by manual linking vs Pods linking
    require 'xcodeproj'
    project_path = 'PlacesI.xcodeproj'
    project = Xcodeproj::Project.open(project_path)
    target = project.targets.first
    phase = target.resources_build_phase
    
    files_to_remove = []
    phase.files_references.each do |ref|
      if ref.path && ref.path.end_with?('.ttf')
        files_to_remove << ref
      end
    end
    
    files_to_remove.each do |ref|
      phase.remove_file_reference(ref)
      puts "Removed #{ref.path} from Project Resources to resolve duplication"
    end
    project.save
  end
end
